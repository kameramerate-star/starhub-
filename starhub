-- LOGICA DE OTIMIZAÇÃO / PERFORMANCE (Sua lógica)
-- =============================================
local optimizationEnabled = false
local disabledCount = 0
local removedCounts = {smokeeffect=0, enemyclone=0, npc=0}

local ToDisable = {Textures=true, VisualEffects=true, Parts=true, Particles=true, Sky=true}
local ToEnable = {FullBright=false}

local PartClasses = {Part=true, UnionOperation=true, WedgePart=true, CornerWedgePart=true, TrussPart=true, MeshPart=true}
local ParticleClasses = {ParticleEmitter=true, Smoke=true, Explosion=true, Sparkles=true, Fire=true, Beam=true, Trail=true}
local VisualEffectClasses = {BloomEffect=true, BlurEffect=true, DepthOfFieldEffect=true, SunRaysEffect=true, ColorCorrectionEffect=true}

local function processObject(obj, isNew)
    if not optimizationEnabled then return false end
    local name = obj.Name:lower()
    local className = obj.ClassName

    if obj:IsA("ParticleEmitter") and obj.Name == "smokeeffect" then
        removedCounts.smokeeffect += 1
        if isNew then task.wait() end
        pcall(obj.Destroy, obj)
        return true
    end

    if obj:IsA("Model") and obj.Name == "enemyclone" then
        local p = obj.Parent
        if p and p.Name == "ClientEffects" then
            removedCounts.enemyclone += 1
            if isNew then task.wait() end
            pcall(obj.Destroy, obj)
            return true
        end
    end

    if obj:IsA("Model") then
        if string.find(name, "clone") or string.find(name, "flicker") or string.find(name, "statz") or string.find(name, "npc") then
            removedCounts.npc += 1
            if isNew then task.wait() end
            pcall(obj.Destroy, obj)
            return true
        end
    end

    if ToDisable.Parts and PartClasses[className] then
        pcall(function() obj.Material = Enum.Material.SmoothPlastic; disabledCount += 1 end)
    elseif ToDisable.Particles and ParticleClasses[className] then
        pcall(function() obj.Enabled = false; disabledCount += 1 end)
    elseif ToDisable.VisualEffects and VisualEffectClasses[className] then
        pcall(function() obj.Enabled = false; disabledCount += 1 end)
    elseif ToDisable.Textures and className == "Texture" then
        pcall(function() obj.Texture = ""; disabledCount += 1 end)
    elseif ToDisable.Sky and className == "Sky" then
        pcall(function() obj.Parent = nil; disabledCount += 1 end)
    end
    return false
end

local function startOptimization()
    if optimizationEnabled then return end
    optimizationEnabled = true
    disabledCount = 0

    local descendants = workspace:GetDescendants()
    for i, v in ipairs(descendants) do
        processObject(v, false)
        if i % 500 == 0 then task.wait() end
    end

    print("✅ Otimização ativa — " .. disabledCount .. " objetos processados")
end

local function setupOptimizationMonitor()
    workspace.DescendantAdded:Connect(function(d)
        processObject(d, true)
    end)
end

local particlesRemovedCount = 0
local particlesConnection = nil

local function removeParticleEmitters()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ParticleEmitter") then
            pcall(function()
                obj:Destroy()
                particlesRemovedCount += 1
            end)
        end
    end
end

local function setupParticlesMonitor()
    if particlesConnection then particlesConnection:Disconnect() end
    particlesConnection = workspace.DescendantAdded:Connect(function(d)
        if d:IsA("ParticleEmitter") then
            task.wait()
            pcall(function()
                d:Destroy()
                particlesRemovedCount += 1
            end)
        end
    end)
end

local function startRemoveParticles()
    particlesRemovedCount = 0
    removeParticleEmitters()
    setupParticlesMonitor()
    print("✅ Efeitos removidos! Total: " .. particlesRemovedCount)
end

