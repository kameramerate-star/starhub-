local function updateStatsUI()
    for player, data in pairs(trackedStatsUI) do
        if not player or not player.Parent or not player.Character then
            pcall(function() data.frame:Destroy() end)
            trackedStatsUI[player] = nil
        else
            local mdValue = FindPlayerMDValue(player)
            local stamValue = FindPlayerStaminaValue(player)
            local stam2Value = FindPlayerStamina2Value(player)
            
            data.modeLabel.Text = "Mode: " .. (mdValue and tostring(mdValue.Value) or "--")
            data.staminaLabel.Text = "Stamina: " .. (stamValue and tostring(math.floor(stamValue.Value)) or "--")
            data.stamina2Label.Text = "Chi: " .. (stam2Value and tostring(math.floor(stam2Value.Value)) or "--")
            data.playerNameLabel.TextColor3 = HUB_COLOR
        end
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not trackedStatsUI[player] then
            createStatUI(player)
        end
    end
    
    statsStroke.Color = HUB_COLOR
end

