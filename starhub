local CONFIG_FOLDER = "AstralHub"
local CONFIG_FILE   = CONFIG_FOLDER .. "/" .. LocalPlayer.Name .. "_config.json"

local function EnsureFolder()
    if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
end

local function ColorToHex(c)
    return string.format("%02X%02X%02X", math.floor(c.R*255), math.floor(c.G*255), math.floor(c.B*255))
end

local function HexToColor(h)
    local r = tonumber(h:sub(1,2), 16) or 155
    local g = tonumber(h:sub(3,4), 16) or 89
    local b = tonumber(h:sub(5,6), 16) or 182
    return Color3.fromRGB(r, g, b)
end

local function SaveConfig()
    EnsureFolder()
    local keyName  = tostring(SILENT_KEY):gsub("Enum.KeyCode.", "")
    local menuName = tostring(MENU_KEY):gsub("Enum.KeyCode.", "")
    local pbName   = tostring(PB_KEY):gsub("Enum.KeyCode.", "")
    local espName  = tostring(ESP_KEY):gsub("Enum.KeyCode.", "")
    local statsName = tostring(STATS_KEY):gsub("Enum.KeyCode.", "")
    local data = string.format(
        '{"fovRadius":%d,"fovVisible":%s,"silentKey":"%s","menuKey":"%s","hubColor":"%s","maxDistance":%d,"pbKey":"%s","espKey":"%s","statsKey":"%s"}',
        FOV_RADIUS, tostring(FOV_VISIBLE), keyName, menuName, ColorToHex(HUB_COLOR), MAX_DISTANCE, pbName, espName, statsName
    )
    writefile(CONFIG_FILE, data)
end

local function LoadConfig()
    EnsureFolder()
    if not isfile(CONFIG_FILE) then return end
    local ok, raw = pcall(readfile, CONFIG_FILE)
    if not ok or not raw then return end
    local fovRadius   = raw:match('"fovRadius":(%d+)')
    local fovVisible  = raw:match('"fovVisible":(%a+)')
    local silentKey   = raw:match('"silentKey":"([^"]+)"')
    local menuKey     = raw:match('"menuKey":"([^"]+)"')
    local hubColor    = raw:match('"hubColor":"([^"]+)"')
    local maxDistance = raw:match('"maxDistance":(%d+)')
    local pbKey       = raw:match('"pbKey":"([^"]+)"')
    local espKey      = raw:match('"espKey":"([^"]+)"')
    local statsKey    = raw:match('"statsKey":"([^"]+)"')
    if fovRadius   then FOV_RADIUS   = tonumber(fovRadius) end
    if fovVisible  then FOV_VISIBLE  = (fovVisible == "true") end
    if maxDistance then MAX_DISTANCE = tonumber(maxDistance) end
    if silentKey   then local e = Enum.KeyCode[silentKey] if e then SILENT_KEY = e end end
    if menuKey     then local e = Enum.KeyCode[menuKey]   if e then MENU_KEY   = e end end
    if pbKey       then local e = Enum.KeyCode[pbKey]     if e then PB_KEY     = e end end
    if espKey      then local e = Enum.KeyCode[espKey]    if e then ESP_KEY    = e end end
    if statsKey    then local e = Enum.KeyCode[statsKey]  if e then STATS_KEY  = e end end
    if hubColor    then HUB_COLOR = HexToColor(hubColor) end
end

LoadConfig()

