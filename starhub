local function MakeSliderRow(labelText, minVal, maxVal, defaultVal, yOrder, onChanged)
    local row = Instance.new("Frame")
    row.Size             = UDim2.new(1, -10, 0, 52)
    row.BackgroundColor3 = BG_ROW
    row.BorderSizePixel  = 0
    row.LayoutOrder      = yOrder
    row.Parent           = listFrame
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 7)

    local lbl = Instance.new("TextLabel")
    lbl.Size                 = UDim2.new(0.7, 0, 0, 22)
    lbl.Position             = UDim2.new(0, 10, 0, 4)
    lbl.BackgroundTransparency = 1
    lbl.Text                 = labelText
    lbl.TextColor3           = Color3.fromRGB(200, 200, 200)
    lbl.TextSize             = 13
    lbl.Font                 = Enum.Font.Gotham
    lbl.TextXAlignment       = Enum.TextXAlignment.Left
    lbl.Parent               = row

    local valLbl = Instance.new("TextLabel")
    valLbl.Size                 = UDim2.new(0.3, -10, 0, 22)
    valLbl.Position             = UDim2.new(0.7, 0, 0, 4)
    valLbl.BackgroundTransparency = 1
    valLbl.Text                 = tostring(defaultVal)
    valLbl.TextColor3           = HUB_COLOR
    valLbl.TextSize             = 13
    valLbl.Font                 = Enum.Font.GothamBold
    valLbl.TextXAlignment       = Enum.TextXAlignment.Right
    valLbl.Parent               = row
    table.insert(coloredElements, { type = "TextColor3", obj = valLbl })

    local bg = Instance.new("Frame")
    bg.Size             = UDim2.new(1, -20, 0, 5)
    bg.Position         = UDim2.new(0, 10, 0, 34)
    bg.BackgroundColor3 = Color3.fromRGB(42, 42, 42)
    bg.BorderSizePixel  = 0
    bg.Parent           = row
    Instance.new("UICorner", bg).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Size             = UDim2.new((defaultVal - minVal) / (maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = HUB_COLOR
    fill.BorderSizePixel  = 0
    fill.Parent           = bg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    table.insert(coloredElements, { type = "BackgroundColor3", obj = fill })

    local isDragging = false
    local hitbox = Instance.new("TextButton")
    hitbox.Size                = UDim2.new(1, 0, 0, 52)
    hitbox.BackgroundTransparency = 1
    hitbox.Text                = ""
    hitbox.Parent              = row

    hitbox.MouseButton1Down:Connect(function() isDragging = true end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and isDragging then
            isDragging = false
            SaveConfig()
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local rel   = math.clamp((input.Position.X - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
            local value = math.floor(minVal + (maxVal - minVal) * rel)
            fill.Size   = UDim2.new(rel, 0, 1, 0)
            valLbl.Text = tostring(value)
            onChanged(value)
        end
    end)
end

